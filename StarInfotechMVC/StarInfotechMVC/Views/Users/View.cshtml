@model User

@{
    ViewData["Title"] = "Star Infotech : View User";
}

<section class="mt-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-4">
                <div class="card">
                    <div class="card-body">
                        <h4 class="card-title"><i class="fa fa-user"></i> User Details</h4>
                        <hr/>
                        <div class="mb-3 row">
                            <label class="col-sm-4 col-form-label fw-bold">ID</label>
                            <div class="col-sm-8">
                                <input type="text" readonly class="form-control-plaintext" value="@Model.Id">
                            </div>
                        </div>
                        <div class="mb-3 row">
                            <label class="col-sm-4 col-form-label fw-bold">First Name</label>
                            <div class="col-sm-8">
                                <input type="text" readonly class="form-control-plaintext" value="@Model.FirstName">
                            </div>
                        </div>
                        <div class="mb-3 row">
                            <label class="col-sm-4 col-form-label fw-bold">Last Name</label>
                            <div class="col-sm-8">
                                <input type="text" readonly class="form-control-plaintext" value="@Model.LastName">
                            </div>
                        </div>
                        <div class="mb-3 row">
                            <label class="col-sm-4 col-form-label fw-bold">Username</label>
                            <div class="col-sm-8">
                                <input type="text" readonly class="form-control-plaintext" value="@Model.Username">
                            </div>
                        </div>
                        <div class="mb-3 row">
                            <label class="col-sm-4 col-form-label fw-bold">Email</label>
                            <div class="col-sm-8">
                                <input type="text" readonly class="form-control-plaintext" value="@Model.Email">
                            </div>
                        </div>
                        <div class="mb-3 row">
                            <label class="col-sm-4 col-form-label fw-bold">Mobile No</label>
                            <div class="col-sm-8">
                                <input type="text" readonly class="form-control-plaintext" value="@Model.MobileNo">
                            </div>
                        </div>
                        <div class="mb-3 row">
                            <label class="col-sm-4 col-form-label fw-bold">Role</label>
                            <div class="col-sm-8">
                                <input type="text" readonly class="form-control-plaintext" value="@Model.Role?.Name">
                            </div>
                        </div>
                        <div class="mb-3 row">
                            <label class="col-sm-4 col-form-label fw-bold">Mobile No</label>
                            <div class="col-sm-8">
                                <input type="text" readonly class="form-control-plaintext" value="@Model.IsActive">
                            </div>
                        </div>
                        <div class="mb-12 row text-center">
                            <a class="btn btn-secondary w-50" style="margin:auto" asp-action="Index" asp-controller="Users">Back to Users</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

