@model User

@{
    ViewData["Title"] = "Star Infotech : Edit User";
}

<section class="mt-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-4">
                <div class="card">
                    <div class="card-body">
                        <h4 class="card-title"><i class="fa fa-user"></i> Edit Details</h4>
                        <hr />
                        <form asp-action="Edit" asp-controller="Users" method="post">
                            <div class="mb-3 row">
                                <label class="col-sm-4 col-form-label fw-bold">ID</label>
                                <div class="col-sm-8">
                                    <input type="text" readonly class="form-control-plaintext" value="@Model.Id">
                                </div>
                            </div>
                            <div class="mb-3 row">
                                <label class="col-sm-4 col-form-label fw-bold">First Name</label>
                                <div class="col-sm-8">
                                    <input type="text" class="form-control" asp-for="FirstName">
                                </div>
                            </div>
                            <div class="mb-3 row">
                                <label class="col-sm-4 col-form-label fw-bold">Last Name</label>
                                <div class="col-sm-8">
                                    <input type="text" class="form-control" asp-for="LastName">
                                </div>
                            </div>
                            <div class="mb-3 row">
                                <label class="col-sm-4 col-form-label fw-bold">Username</label>
                                <div class="col-sm-8">
                                    <input type="text" readonly class="form-control-plaintext" asp-for="Username">
                                </div>
                            </div>
                            <div class="mb-3 row">
                                <label class="col-sm-4 col-form-label fw-bold">Email</label>
                                <div class="col-sm-8">
                                    <input type="text" class="form-control" asp-for="Email">
                                </div>
                            </div>
                            <div class="mb-3 row">
                                <label class="col-sm-4 col-form-label fw-bold">Mobile No</label>
                                <div class="col-sm-8">
                                    <input type="text" class="form-control" asp-for="@Model.MobileNo">
                                </div>
                            </div>
                            <div class="mb-3 row">
                                <label class="col-sm-4 col-form-label fw-bold">Role</label>
                                <div class="col-sm-8">
                                    <select class="form-control" asp-for="RoleId" asp-items="Html.GetEnumSelectList<RoleEnum>()"></select>
                                </div>
                            </div>
                            <div class="mb-3 row">
                                <label class="col-sm-4 col-form-label fw-bold">IsActive</label>
                                <div class="col-sm-8">
                                    <input type="checkbox" class="form-check" asp-for="IsActive" />
                                </div>
                            </div>
                            <div class="mb-12 row text-center">
                                <button type="submit" class="btn btn-primary w-50" style="margin:auto">
                                    Update <i class="fa fa-save"></i>
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
